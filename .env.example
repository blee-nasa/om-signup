# Local development environment.
# Copy to `.env` (gitignored) — the dev server, Drizzle, and integration tests read it.

# Postgres connection. Matches compose.yml defaults (host port 5438).
DATABASE_URL=postgres://om_signup:om_signup@localhost:5438/om_signup

# Port the API / single-app server listens on.
PORT=3000

# Override the host port Docker maps Postgres to (defaults to 5438).
# POSTGRES_PORT=5438
