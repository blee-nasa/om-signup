{
  "name": "@om-signup/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun --watch --env-file=../../.env src/index.ts",
    "start": "bun run src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:push": "bun --env-file=../../.env x drizzle-kit push",
    "db:generate": "bun --env-file=../../.env x drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env x drizzle-kit migrate"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "4.1.7"
  }
}
