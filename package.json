{
  "name": "om-signup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"bun run --cwd apps/api dev\" \"bun run --cwd apps/web dev\"",
    "build": "bun run --cwd apps/web build",
    "start": "bun run --cwd apps/api start",
    "lint": "oxlint apps",
    "lint:fix": "oxlint apps --fix",
    "typecheck": "bun run --cwd apps/api typecheck && bun run --cwd apps/web typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "bun run --cwd apps/api db:generate",
    "db:migrate": "bun run --cwd apps/api db:migrate",
    "db:push": "bun run --cwd apps/api db:push",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "4.1.7",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "vitest": "4.1.7"
  }
}
